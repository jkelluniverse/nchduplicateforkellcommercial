# ============================================================================
# Kell Commercial Leasing — environment template
# Copy to `.env` and fill in. NEVER commit the real `.env` (it is gitignored).
#
# This app is for KELL COMMERCIAL ONLY. It must use its OWN separate, empty
# database and its OWN read-only Rentec Direct connection. It must NEVER point
# at Nice City Homes' database, DoorLoop, or Google account.
# ============================================================================

# --- Core ------------------------------------------------------------------
# Postgres connection string for THIS app's own separate database (not NCH's).
DATABASE_URL=postgres://user:password@host:5432/kellcommercial

# HTTP port the server listens on (Railway injects this; 8080 locally).
PORT=8080

# Base path the SPA/router is mounted under. Leave as "/" for a dedicated domain.
BASE_PATH=/

NODE_ENV=production

# Secret used to sign session/JWT login tokens. Generate a long random string:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# --- Rentec Direct (READ-ONLY) ---------------------------------------------
# Read-only API key for the Kell Commercial / Dad's portfolio Rentec account.
# Base URL defaults to https://secure.rentecdirect.com/api/v3 if unset.
RENTEC_API_KEY=
# RENTEC_API_BASE=https://secure.rentecdirect.com/api/v3

# --- Web push notifications (optional; task / past-due alerts) --------------
# Generate a fresh pair (do NOT reuse NCH's keys):
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- Email (optional; daily payment-reminder emails) -----------------------
# Uses a Google service account to send via Gmail API. Leave blank to disable
# email — the app still works, it just won't send reminder emails.
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_IMPERSONATE_USER=
